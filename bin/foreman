#!/usr/bin/env bash
# Foreman shell wrapper.
set -euo pipefail
# Resolve symlinks so ~/.local/bin/foreman -> /real/path/foreman/bin/foreman
# still finds the repo root.
_resolve() {
  local src="$1" dir
  while [ -L "$src" ]; do
    dir="$(cd -P "$(dirname "$src")" >/dev/null && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" >/dev/null && pwd
}
FOREMAN_HOME="${FOREMAN_HOME:-$(cd "$(_resolve "$0")/.." && pwd)}"
TOOLS="$FOREMAN_HOME/foreman/tools"
PROJECT="${FOREMAN_PROJECT:-$PWD}"
# Export so sub-agents that shell out with `foreman ...` inherit these.
export FOREMAN_HOME FOREMAN_PROJECT="$PROJECT"

cmd="${1:-}"; shift || true

# Friendly aliases (user-facing)
case "$cmd" in
  ship)   cmd="run" ;;
  status) cmd="next" ;;
  check)  cmd="doctor" ;;
esac

case "$cmd" in
  info)     exec python3 "$TOOLS/project_info.py" --project "$PROJECT" "$@" ;;
  plan)     exec python3 "$TOOLS/plan.py"         --project "$PROJECT" "$@" ;;
  validate) exec python3 "$TOOLS/validate.py"     --project "$PROJECT" "$@" ;;
  verify)   exec python3 "$TOOLS/verify.py"       --project "$PROJECT" "$@" ;;
  commit)   exec python3 "$TOOLS/commit.py"       --project "$PROJECT" "$@" ;;
  rollback)
    # Safe scoped rollback: require --task-id unless hard flags passed through
    exec python3 "$TOOLS/rollback.py" --project "$PROJECT" "$@"
    ;;
  init)     exec python3 "$TOOLS/init.py"         --project "$PROJECT" "$@" ;;
  debt)     exec python3 "$TOOLS/debt.py"         --project "$PROJECT" "$@" ;;
  run)      exec python3 "$TOOLS/run.py"          --project "$PROJECT" "$@" ;;
  ready)    exec python3 "$TOOLS/ready.py"        --project "$PROJECT" "$@" ;;
  discover) exec python3 "$TOOLS/discover.py"     --project "$PROJECT" "$@" ;;
  execute)  exec python3 "$TOOLS/execute.py"      --project "$PROJECT" "$@" ;;
  design)
    sub="${1:-status}"; shift || true
    case "$sub" in
      status|"") exec python3 "$TOOLS/design.py" --project "$PROJECT" --status "$@" ;;
      show)      exec python3 "$TOOLS/design.py" --project "$PROJECT" --show "$@" ;;
      # show --open uses $EDITOR when set
      run)       exec python3 "$TOOLS/design.py" --project "$PROJECT" --run "$@" ;;
      approve)   exec python3 "$TOOLS/design.py" --project "$PROJECT" --approve "$@" ;;
      reject)
        reason="${1:-}"; [ -n "${1:-}" ] && shift || true
        exec python3 "$TOOLS/design.py" --project "$PROJECT" --reject ${reason:+"$reason"} "$@" ;;
      *)
        echo '{"ok":false,"message":"unknown design subcommand","hint":"foreman design status|show|run|approve|reject"}'
        exit 2 ;;
    esac
    ;;
  memory)
    sub="${1:-stats}"; shift || true
    case "$sub" in
      stats|"")
        exec python3 "$TOOLS/memory.py" --project "$PROJECT" --stats "$@" ;;
      retrieve)
        exec python3 "$TOOLS/memory.py" --project "$PROJECT" --retrieve "$@" ;;
      decisions)
        exec python3 "$TOOLS/memory.py" --project "$PROJECT" --decisions "$@" ;;
      rebuild)
        exec python3 "$TOOLS/memory.py" --project "$PROJECT" --rebuild "$@" ;;
      rg)
        if [ -z "${1:-}" ]; then
          echo '{"ok":false,"message":"memory rg requires a pattern","hint":"foreman memory rg ClassName [--glob \"*.dart\"]"}'
          exit 2
        fi
        pat="$1"; shift
        exec python3 "$TOOLS/memory.py" --project "$PROJECT" --rg "$pat" "$@" ;;
      cache-clear)
        exec python3 "$TOOLS/memory.py" --project "$PROJECT" --cache-clear "$@" ;;
      rg-status)
        exec python3 "$TOOLS/memory.py" --project "$PROJECT" --rg-status "$@" ;;
      *)
        echo "{\"ok\":false,\"message\":\"unknown memory subcommand: $sub\",\"hint\":\"try: stats|retrieve|decisions|rebuild|rg|cache-clear|rg-status\"}"
        exit 2 ;;
    esac
    ;;

  deploy)
    sub="${1:-list}"; shift || true
    case "$sub" in
      list)
        exec python3 "$TOOLS/deploy.py" --project "$PROJECT" --list "$@" ;;
      install)
        exec python3 "$TOOLS/deploy.py" --project "$PROJECT" --install "$@" ;;
      *)
        echo "{\"ok\":false,\"message\":\"unknown deploy subcommand: $sub\",\"hint\":\"try: list | install\"}"
        exit 2 ;;
    esac
    ;;

  spawn)
    if [ -z "${1:-}" ]; then
      echo '{"ok":false,"message":"spawn requires a role","hint":"foreman spawn <role> [task_id]   roles: product_owner|designer|architect|qa_lead|developer|tester|reviewer|refactorer|debugger","note":"spawn only prints a prompt — use foreman run or the OpenCode foreman agent to execute"}'
      exit 2
    fi
    role="$1"; shift
    tid="${1:-}"; [ -n "$tid" ] && shift || true
    exec python3 "$TOOLS/spawn.py" --project "$PROJECT" --role "$role" \
      ${tid:+--task-id "$tid"} "$@"
    ;;

  handoff)
    if [ -z "${1:-}" ] || [ -z "${2:-}" ]; then
      echo '{"ok":false,"message":"handoff requires task-id and role","hint":"printf \"%s\" \"$JSON\" | foreman handoff <task_id> <role>","example":"foreman handoff scaffold architect"}'
      exit 2
    fi
    tid="$1"; shift
    role="$1"; shift
    exec python3 "$TOOLS/handoff.py" --project "$PROJECT" \
      --task-id "$tid" --role "$role" --stdin "$@"
    ;;

  state)
    sub="${1:-summary}"; shift || true
    case "$sub" in
      pending|ready|blocked|all|dag|reset|resume|escalations)
        exec python3 "$TOOLS/state.py" --project "$PROJECT" "--$sub" "$@" ;;
      import)
        exec python3 "$TOOLS/state.py" --project "$PROJECT" --import "$@" ;;
      add)
        if [ -z "${1:-}" ] || [ -z "${2:-}" ]; then
          echo '{"ok":false,"message":"state add requires <id> and description","hint":"foreman state add scaffold \"Scaffold MaterialApp\""}'
          exit 2
        fi
        tid="$1"; shift
        desc="$1"; shift
        exec python3 "$TOOLS/state.py" --project "$PROJECT" --add "$tid" --desc "$desc" "$@" ;;
      done)
        if [ -z "${1:-}" ]; then
          echo '{"ok":false,"message":"state done requires a task-id","hint":"foreman state done scaffold"}'
          exit 2
        fi
        tid="$1"; shift
        exec python3 "$TOOLS/state.py" --project "$PROJECT" --mark "$tid" --status done "$@" ;;
      fail)
        if [ -z "${1:-}" ]; then
          echo '{"ok":false,"message":"state fail requires a task-id","hint":"foreman state fail scaffold \"validate failed\""}'
          exit 2
        fi
        tid="$1"; shift
        err="${1:-}"; [ -n "${1:-}" ] && shift || true
        exec python3 "$TOOLS/state.py" --project "$PROJECT" --mark "$tid" --status failed ${err:+--error "$err"} "$@" ;;
      task)
        if [ -z "${1:-}" ]; then
          echo '{"ok":false,"message":"state task requires a task-id","hint":"foreman state task scaffold"}'
          exit 2
        fi
        tid="$1"; shift
        exec python3 "$TOOLS/state.py" --project "$PROJECT" --task "$tid" "$@" ;;
      plan)
        if [ -z "${1:-}" ]; then
          echo '{"ok":false,"message":"state plan requires a task-id","hint":"foreman state plan scaffold   # smart: only needed roles"}'
          exit 2
        fi
        tid="$1"; shift
        exec python3 "$TOOLS/state.py" --project "$PROJECT" --plan "$tid" "$@" ;;
      guide)
        if [ -z "${1:-}" ]; then
          echo '{"ok":false,"message":"state guide requires a task-id","hint":"foreman state guide scaffold   # shows the next 1–2 steps only"}'
          exit 2
        fi
        tid="$1"; shift
        exec python3 "$TOOLS/state.py" --project "$PROJECT" --guide "$tid" "$@" ;;
      auto)
        if [ -z "${1:-}" ]; then
          echo '{"ok":false,"message":"state auto requires a task-id","hint":"foreman state auto scaffold","note":"auto only PRINTS the remaining command sequence (smart roles) — it does not execute. Use: foreman run"}'
          exit 2
        fi
        tid="$1"; shift
        exec python3 "$TOOLS/state.py" --project "$PROJECT" --auto "$tid" "$@" ;;
      batch)
        n="${1:-3}"; [ -n "${1:-}" ] && shift || true
        exec python3 "$TOOLS/state.py" --project "$PROJECT" --batch "$n" "$@" ;;
      template)
        if [ -z "${1:-}" ]; then
          echo '{"ok":false,"message":"state template requires a name","hint":"foreman state template todo|chat|blog"}'
          exit 2
        fi
        name="$1"; shift
        exec python3 "$TOOLS/state.py" --project "$PROJECT" --template "$name" "$@" ;;
      summary|"")
        exec python3 "$TOOLS/state.py" --project "$PROJECT" "$@" ;;
      *)
        echo "{\"ok\":false,\"message\":\"unknown state subcommand: $sub\",\"hint\":\"try: pending|ready|blocked|all|dag|reset|resume|escalations|import|add|done|fail|task|plan|guide|auto|batch|template|summary\",\"tip\":\"empty DAG? foreman state template todo   or   foreman run\"}"
        exit 2 ;;
    esac
    ;;

  next|status)
    brief=$(python3 "$TOOLS/project_info.py" --project "$PROJECT" --brief 2>/dev/null || echo "?")
    ready=$(python3 "$TOOLS/state.py" --project "$PROJECT" --ready 2>/dev/null || echo '{"ok":false}')
    total=$(python3 "$TOOLS/state.py" --project "$PROJECT" 2>/dev/null || echo '{"total":0}')
    FOREMAN_HOME="$FOREMAN_HOME" FOREMAN_PROJECT="$PROJECT" python3 - "$ready" "$total" "$brief" <<'PY2'
import json, sys, os
sys.path.insert(0, os.environ["FOREMAN_HOME"])
from foreman import ui
from foreman.readiness import assess as assess_ready
from foreman.design_gate import assess_design
from foreman.log import metrics_summary
try:
    r = json.loads(sys.argv[1])
except Exception:
    r = {"ok": False, "count": 0, "tasks": []}
try:
    t = json.loads(sys.argv[2])
except Exception:
    t = {"total": 0}
brief = sys.argv[3] if len(sys.argv) > 3 else "?"
proj = os.environ.get("FOREMAN_PROJECT") or "."
prod = assess_ready(proj)
des = assess_design(proj)
met = metrics_summary(os.path.join(proj, ".foreman"))
n = r.get("count", 0)
tot = t.get("total", 0)
if not prod.get("ready"):
    guide = "WAITING FOR: product docs — foreman discover && foreman ready"
elif not des.get("approved"):
    guide = "WAITING FOR: design approve — foreman design show && foreman design approve && foreman run"
elif tot == 0:
    guide = "Product+design ready. Run: foreman run"
elif n == 0:
    guide = "No open tasks (done or blocked). foreman run to resume or foreman report --write"
else:
    tid = r["tasks"][0]["id"]
    guide = f"Ready to build next: {tid}. Run: foreman run"
data = {
    "brief": brief.strip(),
    "ready": r,
    "total_tasks": tot,
    "product_ready": prod.get("ready"),
    "design_approved": des.get("approved"),
    "design_status": des.get("status"),
    "handoff_success_rate": met.get("handoff_success_rate"),
    "guidance": guide,
    "how_to_run": "foreman run",
}
ui.status_view(data)
print(json.dumps(data, indent=2))
PY2
    ;;

  metrics)
    python3 - "$FOREMAN_HOME" "$PROJECT" <<'PY'
import json, os, sys
sys.path.insert(0, sys.argv[1])
from foreman.log import metrics_summary
proj = sys.argv[2]
md = os.path.join(proj, ".foreman")
print(json.dumps(metrics_summary(md), indent=2))
PY
    ;;

  report)
    exec python3 "$TOOLS/report.py" --project "$PROJECT" "$@"
    ;;

  prove)
    # Deterministic ship proof (no live LLM). Optional path: prove /tmp/app
    prove_dir="${1:-$PROJECT}"
    if [ -n "${1:-}" ]; then
      shift || true
      prove_dir="$(cd "$prove_dir" 2>/dev/null && pwd)" || prove_dir="$1"
    fi
    exec python3 "$TOOLS/prove.py" --project "${prove_dir:-$PROJECT}" "$@"
    ;;

  log)
    logfile="$PROJECT/.foreman/log.jsonl"
    if [ ! -f "$logfile" ]; then
      echo '{"ok":true,"message":"no log yet"}'
      exit 0
    fi
    if [ "${1:-}" = "--summary" ]; then
      python3 - "$logfile" <<'PYEOF'
import json, sys
from collections import Counter
by_tool, exits, ms_by_tool = Counter(), Counter(), {}
n = 0
for line in open(sys.argv[1]):
    try: r = json.loads(line)
    except Exception: continue
    n += 1
    by_tool[r.get("tool","?")] += 1
    exits[r.get("exit",0)] += 1
    t = r.get("tool","?"); ms_by_tool.setdefault(t, []).append(r.get("ms",0))
out = {"ok": True, "total_calls": n, "by_tool": dict(by_tool.most_common()),
       "exit_codes": dict(exits),
       "avg_ms": {t: round(sum(v)/len(v)) for t,v in ms_by_tool.items() if v}}
print(json.dumps(out, indent=2))
PYEOF
    elif [ "${1:-}" = "--task" ]; then
      tid="${2:?task-id required}"
      python3 - "$logfile" "$tid" <<'PYEOF'
import json, sys
tid = sys.argv[2]
out = []
for line in open(sys.argv[1]):
    try: r = json.loads(line)
    except Exception: continue
    if r.get("task_id") == tid or (tid in r.get("args", [])):
        out.append(r)
print(json.dumps({"ok": True, "task_id": tid, "count": len(out), "events": out}, indent=2))
PYEOF
    else
      n="${1:-20}"
      tail -n "$n" "$logfile"
    fi
    ;;

  doctor)
    python3 - "$FOREMAN_HOME" "$PROJECT" <<'PYEOF'
import json, os, shutil, sys
sys.path.insert(0, sys.argv[1])
from foreman import ui
home, proj = sys.argv[1], sys.argv[2]
checks = []
def c(name, ok, detail=""):
    checks.append({"check": name, "ok": bool(ok), "detail": detail})
c("FOREMAN_HOME", os.path.isdir(os.path.join(home, "foreman", "tools")), home)
role_files = [f for f in os.listdir(os.path.join(home, "prompts", "roles")) if f.endswith(".txt")]
c("prompts/roles", len(role_files) >= 9, f"expect ≥9 role files (have {len(role_files)})")
c("opencode/agent/foreman.md", os.path.exists(os.path.join(home, "opencode", "agent", "foreman.md")))
role_agents = ["product_owner","designer","architect","qa_lead","developer","tester","reviewer","refactorer","debugger"]
have_roles = sum(1 for r in role_agents if os.path.exists(os.path.join(home, "opencode", "agent", f"{r}.md")))
c("opencode role agents", have_roles == 9, f"{have_roles}/9")
c("opencode/command/ship.md", os.path.exists(os.path.join(home, "opencode", "command", "ship.md")))
c("templates", len([f for f in os.listdir(os.path.join(home, "templates")) if f.endswith(".json")]) >= 3, "expect >=3 JSON templates")
c("python3", shutil.which("python3") is not None)
c("opencode", shutil.which("opencode") is not None, "required for foreman run")
c("git", shutil.which("git") is not None)
c("ripgrep (rg)", shutil.which("rg") is not None or shutil.which("ripgrep") is not None,
  "(optional but recommended)")
c("flutter", shutil.which("flutter") is not None, "(optional)")
c("dart", shutil.which("dart") is not None, "(optional)")
c("gh", shutil.which("gh") is not None, "(optional)")
mem_dir = os.path.join(proj, ".foreman", "memory")
c(".foreman/memory", True, mem_dir if os.path.isdir(mem_dir) else "created on first handoff")
c("PROJECT exists", os.path.isdir(proj), proj)
c("PROJECT is git repo", os.path.isdir(os.path.join(proj, ".git")), "(optional)")
xdg = os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config"))
g_agent = os.path.join(xdg, "opencode", "agent", "foreman.md")
p_agent = os.path.join(proj, ".opencode", "agent", "foreman.md")
agent_ok = any(os.path.exists(p) or os.path.islink(p) for p in (
    p_agent, os.path.join(proj, ".opencode", "agents", "foreman.md"),
    g_agent, os.path.join(xdg, "opencode", "agents", "foreman.md")))
c("foreman agent (project or global)", agent_ok,
  "global" if agent_ok else g_agent)
c(".foreman/", os.path.isdir(os.path.join(proj, ".foreman")), "(optional)")
tasks = os.path.join(proj, ".foreman", "tasks.json")
if os.path.exists(tasks):
    try:
        n = len(json.load(open(tasks)))
        c("task DAG", True, f"{n} tasks")
    except Exception:
        c("task DAG", False, "tasks.json unreadable")
else:
    c("task DAG", True, "empty — run foreman run after init")
failed = [x for x in checks if not x["ok"] and "optional" not in x["detail"].lower()]
next_steps = []
if any(x["check"] == "opencode" and not x["ok"] for x in checks):
    next_steps.append("Install OpenCode: https://opencode.ai")
if any(x["check"] == "foreman agent (project or global)" and not x["ok"] for x in checks):
    next_steps.append(f"One-time global install: {home}/install.sh")
if not failed:
    next_steps.append("Next: foreman discover  →  foreman ready  →  foreman run")
data = {"ok": len(failed) == 0, "checks": checks,
        "critical_failures": len(failed), "next": next_steps}
ui.doctor_view(data)
print(json.dumps(data, indent=2))
sys.exit(0 if not failed else 1)
PYEOF
    ;;

  branch)
    name="${1:?branch name required}"; shift
    exec git -C "$PROJECT" checkout -B "$name" "$@"
    ;;

  pr)
    title="${1:?title required}"; shift
    body="${1:-Automated PR by foreman}"; [ -n "${1:-}" ] && shift || true
    if ! command -v gh >/dev/null 2>&1; then
      echo '{"ok":false,"message":"gh CLI not installed. See: cli.github.com"}'
      exit 1
    fi
    exec gh pr create -R "$(git -C "$PROJECT" remote get-url origin 2>/dev/null | sed 's|.*/\([^/]*/[^/]*\)\.git|\1|')" \
      --title "$title" --body "$body" "$@"
    ;;

  demo|ux-demo)
    # Show mock pretty UX (no project needed)
    python3 - "$FOREMAN_HOME" <<'PY'
import sys, os
sys.path.insert(0, sys.argv[1])
from foreman.ui import demo_mock
print(demo_mock())
PY
    ;;

  ""|help|-h|--help)
    # Default help = simple user surface. Agent tools: foreman help --agent
    if [ "${1:-}" = "--agent" ] || [ "${1:-}" = "agent" ] || [ "${1:-}" = "--all" ]; then
      cat <<EOF
foreman — agent / advanced commands (used by the AI, not day-to-day)

  state pending|ready|blocked|all|dag|reset|resume|escalations
  state add <id> "<desc>" [--deps a,b] [--acceptance "..."]
  state done <id> | state fail <id> [error]
  state task|plan|guide|auto <id>
  state batch [N] | import | template <todo|chat|blog>

  spawn <role> [task_id] [--load-from ROLE] [--error ...] [--self-handoff]
  handoff <task_id> <role>          # stdin: JSON

  validate | verify | commit | rollback --task-id T
  ready | discover | execute [--mock|--task-id T|--template todo]
  design status|show|run|approve|reject
  metrics                         # handoff / role_session proxies
  report [--write] [--live]       # field-report draft
  prove [dir]                     # deterministic control-plane ship proof
  info | plan | log | debt | memory …
  branch <name> | pr "<title>"
  deploy list | deploy install --device <id>

Prefer: foreman discover → ready → design approve → run
EOF
    else
      cat <<EOF
Foreman — autonomous Flutter app builder

You write what to build. Foreman builds it.

Setup (once)
  1. Install OpenCode:  https://opencode.ai
  2. Install Flutter:   https://docs.flutter.dev/get-started
  3. Install Foreman:
       git clone https://github.com/Surya-SP/foreman
       cd foreman && ./install.sh
       export PATH="\$HOME/.local/bin:\$PATH"

Build an app (outside the foreman repo — any Flutter project)
  1. flutter create my_app && cd my_app
  2. foreman doctor
  3. foreman discover        # interactive PRD + design
  4. foreman ready           # product docs gate
  5. foreman design run && foreman design show && foreman design approve
  6. foreman run             # autonomous OpenCode ship

Everyday commands
  foreman discover           Interactive product brainstorm → PRD + design
  foreman ready              Check if product docs are complete
  foreman design run|show|approve   Design language (human review; show --open)
  foreman metrics            Handoff / role session proxies
  foreman report [--write]   Field-report draft from local state
  foreman prove [dir]        Deterministic ship proof (mock roles + real code)
  foreman run                Discover/design gates, then autonomous OpenCode ship
  foreman execute            Hard loop: OpenCode role agents per task step
  foreman status             What is left to do
  foreman doctor             Fix install / PATH problems
  foreman init               Empty PRD + design templates
  foreman deploy list|install
  foreman demo               Preview terminal look (mock)

Flow
  discover → ready → design approve → run
  (run = OpenCode --agent <role> per step)

Tips
  • Restart OpenCode after install
  • PATH: export PATH="\$HOME/.local/bin:/opt/homebrew/bin:\$PATH"
  • Stuck mid-build? foreman run again
  • TUI: opencode --agent foreman then /ship

Agent tools:  foreman help --agent
EOF
    fi
    ;;
  *)
    echo "{\"ok\":false,\"message\":\"unknown command: $cmd\",\"hint\":\"foreman help   |   foreman run   |   foreman status\"}" >&2
    exit 2 ;;
esac
